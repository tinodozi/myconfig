#		format_up = "Bitcoin: %s"
#		format_down = "Bitcon: ---"
#		format_separator = ""
#		path = "/home/debian/conf/bitcoin.sh"
#}

wireless _first_ {
        #format_up = "W:(%quality at %essid) %ip"
        format_up = "Wireless:%quality at %essid"
        format_down = "Wireless:----"
}

ethernet _first_ {
        #format_up = "E:%ip (%speed)"
        format_up = "Ethernet:%speed"
        format_down = "Ethernet:----"
}

battery all {
        #format = "Batt:%status (%percentage) %remaining"
        format = "🔋 %percentage %remaining"
}

disk "/" {
        format = "💽 %avail"
}

load {
        format = "%1min"
}

memory {
        format = "💻 %available"
        threshold_degraded = "1G"
        format_degraded = "MEMORY < %available"
}

tztime local {
        format = "🗓️ %Y-%m-%d %H:%M:%S"
}

